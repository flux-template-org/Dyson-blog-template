---
import BaseLayout from "../layout/BaseLayout.astro";
import BaseHead from "../components/global/BaseHead.astro";
import Title from "../components/Title.jsx";
import TwoColumnLayout from "../components/TwoColumnLayout.jsx";
import Cta from "../components/global/Cta.jsx";

import PrivacyData from "../data/privacy.json";
import ctaData from "../data/cta.json";
---

<BaseLayout>
  <BaseHead />
  <Title title="Imprint" />
  <TwoColumnLayout
    data={{
      sections: PrivacyData.sections,
      updated: PrivacyData.updated,
    }}
  />
  <Cta data={ctaData} />
</BaseLayout>
