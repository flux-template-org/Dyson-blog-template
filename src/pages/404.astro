---
import BaseHead from "../components/global/BaseHead.astro";
---

<html lang="en">
  <head>
    <BaseHead />
  </head>
  <body class="flex flex-col min-h-screen bg-white">
    <main
      class="flex flex-col items-center justify-center flex-1 text-center py-24"
    >
      <h1 class="text-5xl md:text-6xl font-extrabold mb-4">404</h1>
      <p class="text-lg md:text-xl mb-8">
        Sorry, the page you are looking for does not exist.
      </p>
      <a
        href="/"
        class="inline-block px-6 py-2 rounded font-medium bg-black text-white hover:bg-sky-700 transition-colors"
      >
        Go back home
      </a>
    </main>
  </body>
</html>
