---
import BaseLayout from "../layout/BaseLayout.astro";
import BaseHead from "../components/global/BaseHead.astro";
import BentoCard from "../components/cards/BentoCard.jsx";
import Cards from "../components/cards/Card.jsx";
import Hero from "../components/landing/Hero.jsx";
import Stats from "../components/landing/Stats.jsx";
import Marquee from "../components/landing/Marquee.jsx";
import Features from "../components/landing/Features.jsx";
import Testimonials from "../components/landing/Testimonials.jsx";
import Title from "../components/Title.jsx";
import Cta from "../components/global/Cta.jsx";

import cards from "../data/product.json";
import journalData from "../data/journal.json";
import statsData from "../data/stats.json";
import marqueeData from "../data/marquee.json";
import featuresData from "../data/features.json";
import testimonialsData from "../data/testimonials.json";
import ctaData from "../data/cta.json";
---

<BaseLayout transparentNav={true}>
  <BaseHead />
  <Hero client:load />
  <Stats data={statsData} client:load />
  <Marquee items={marqueeData} client:load />
  <Title title="Dyson Inspired" client:load />
  <BentoCard data={cards} client:load />
  <Features data={featuresData} client:load />
  <Cards data={journalData} sectionTitle="Inspired updates" maxCards={4} basePath="/journal" seeMoreHref="/journal" client:load />
  <Testimonials data={testimonialsData} client:load />
  <Cta data={ctaData} client:load />
</BaseLayout>
